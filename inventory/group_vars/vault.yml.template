# ── Velero OneDrive Backup ────────────────────────────────────────────────────
# Step 1: Install rclone on your laptop — https://rclone.org/install/
# Step 2: Run 'rclone config' → choose OneDrive → follow browser OAuth flow
# Step 3: Copy the values from ~/.config/rclone/rclone.conf
velero_onedrive_client_id: ""     # Leave blank for personal OneDrive
velero_onedrive_client_secret: "" # Leave blank for personal OneDrive
velero_onedrive_token: ""         # Full JSON token blob from rclone config
