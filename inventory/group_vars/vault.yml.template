---
# =============================================================================
# Ansible Vault encrypted secrets template
# Usage:
#   1. Copy this file to vault.yml:  cp vault.yml.template vault.yml
#   2. Edit with real values:        nano vault.yml
#   3. Encrypt:                      ansible-vault encrypt vault.yml
#   4. Run playbook:                 ansible-playbook site.yml --ask-vault-pass
# =============================================================================

# ── Container Registry ────────────────────────────────────────────────────────
harbor_admin_password: "CHANGE_ME_Harbor_Password"

# ── MinIO Object Storage ──────────────────────────────────────────────────────
minio_root_user: "minioadmin"
minio_root_password: "CHANGE_ME_MinIO_Password"

# ── Kong API Gateway ──────────────────────────────────────────────────────────
kong_db_password: "CHANGE_ME_Kong_DB_Password"

# ── Databases ─────────────────────────────────────────────────────────────────
postgresql_password: "CHANGE_ME_PG_Password"
mysql_root_password: "CHANGE_ME_MySQL_Password"
redis_password: "CHANGE_ME_Redis_Password"
rabbitmq_password: "CHANGE_ME_RabbitMQ_Password"
rabbitmq_erlang_cookie: "CHANGE_ME_RabbitMQ_Erlang_Cookie"

# ── Monitoring ────────────────────────────────────────────────────────────────
grafana_admin_password: "CHANGE_ME_Grafana_Password"

# ── Gitea (email-based auth) ──────────────────────────────────────────────────
gitea_admin_password: "CHANGE_ME_Gitea_Password"
gitea_db_password: "CHANGE_ME_Gitea_DB_Password"
