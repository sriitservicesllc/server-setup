---
apiVersion: v1
kind: Service
metadata:
  name: gitea
  namespace: {{ gitea_namespace }}
  labels:
    app.kubernetes.io/name: gitea
spec:
  type: ClusterIP
  selector:
    app.kubernetes.io/name: gitea
  ports:
    - name: http
      port: 3000
      targetPort: http
---
apiVersion: v1
kind: Service
metadata:
  name: gitea-ssh
  namespace: {{ gitea_namespace }}
  labels:
    app.kubernetes.io/name: gitea
spec:
  type: LoadBalancer
  selector:
    app.kubernetes.io/name: gitea
  ports:
    - name: ssh
      port: 22
      targetPort: ssh
