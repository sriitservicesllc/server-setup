---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: gitea
  namespace: {{ gitea_namespace }}
  labels:
    app.kubernetes.io/name: gitea
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: gitea
  template:
    metadata:
      labels:
        app.kubernetes.io/name: gitea
    spec:
      securityContext:
        fsGroup: 1000
      containers:
        - name: gitea
          image: docker.gitea.com/gitea:{{ gitea_image_tag }}
          imagePullPolicy: IfNotPresent
          env:
            - name: USER_UID
              value: "1000"
            - name: USER_GID
              value: "1000"
            - name: GITEA__server__DOMAIN
              value: "{{ gitea_hostname }}"
            - name: GITEA__server__ROOT_URL
              value: "https://{{ gitea_hostname }}/"
            - name: GITEA__server__SSH_DOMAIN
              value: "{{ gitea_hostname }}"
            - name: GITEA__server__SSH_PORT
              value: "22"
            - name: GITEA__server__SSH_LISTEN_PORT
              value: "22"
            - name: GITEA__server__DISABLE_SSH
              value: "false"
            - name: GITEA__server__LFS_START_SERVER
              value: "true"
            - name: GITEA__database__DB_TYPE
              value: "postgres"
            - name: GITEA__database__HOST
              value: "postgresql.databases.svc.{{ cluster_domain }}:5432"
            - name: GITEA__database__NAME
              value: "gitea"
            - name: GITEA__database__USER
              value: "gitea"
            - name: GITEA__database__PASSWD
              valueFrom:
                secretKeyRef:
                  name: gitea-secrets
                  key: db-password
            - name: GITEA__cache__ADAPTER
              value: "memory"
            - name: GITEA__session__PROVIDER
              value: "memory"
            - name: GITEA__queue__TYPE
              value: "level"
            - name: GITEA__repository__DEFAULT_BRANCH
              value: "main"
            - name: GITEA__repository__DEFAULT_PRIVATE
              value: "true"
            - name: GITEA__actions__ENABLED
              value: "true"
            - name: GITEA__service__REGISTER_EMAIL_CONFIRM
              value: "{{ 'true' if gitea_smtp_enabled else 'false' }}"
            - name: GITEA__service__DISABLE_REGISTRATION
              value: "{{ 'false' if gitea_allow_registration else 'true' }}"
            - name: GITEA__service__REQUIRE_SIGNIN_VIEW
              value: "{{ 'true' if gitea_require_signin else 'false' }}"
            - name: GITEA__service__DEFAULT_KEEP_EMAIL_PRIVATE
              value: "true"
            - name: GITEA__service__ALLOW_ONLY_EXTERNAL_REGISTRATION
              value: "false"
            - name: GITEA__service__ENABLE_NOTIFY_MAIL
              value: "{{ 'true' if gitea_smtp_enabled else 'false' }}"
            - name: GITEA__mailer__ENABLED
              value: "{{ gitea_smtp_enabled | bool | ternary('true', 'false') }}"
            - name: GITEA__mailer__SMTP_ADDR
              value: "{{ gitea_smtp_host }}"
            - name: GITEA__mailer__SMTP_PORT
              value: "{{ gitea_smtp_port | string }}"
            - name: GITEA__mailer__FROM
              value: "{{ gitea_smtp_from }}"
            - name: GITEA__mailer__USER
              value: "{{ gitea_smtp_user }}"
            - name: GITEA__mailer__PASSWD
              valueFrom:
                secretKeyRef:
                  name: gitea-secrets
                  key: smtp-password
            - name: GITEA__mailer__PROTOCOL
              value: "smtp+starttls"
            - name: GITEA__security__INSTALL_LOCK
              value: "true"
          ports:
            - name: http
              containerPort: 3000
            - name: ssh
              containerPort: 22
          volumeMounts:
            - name: data
              mountPath: /data
          resources:
            requests:
              memory: 256Mi
              cpu: 200m
            limits:
              memory: 1Gi
              cpu: 1000m
      volumes:
        - name: data
          persistentVolumeClaim:
            claimName: gitea-data
