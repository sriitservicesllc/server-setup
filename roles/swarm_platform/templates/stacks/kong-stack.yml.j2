version: "3.8"

services:
  kong:
    image: kong:3.7
    environment:
      KONG_DATABASE: "off"
      KONG_DECLARATIVE_CONFIG: /kong/kong.yml
      KONG_PROXY_ACCESS_LOG: /dev/stdout
      KONG_ADMIN_ACCESS_LOG: /dev/stdout
      KONG_PROXY_ERROR_LOG: /dev/stderr
      KONG_ADMIN_ERROR_LOG: /dev/stderr
      KONG_ADMIN_LISTEN: 0.0.0.0:8001
    volumes:
      - "{{ swarm_data_root }}/kong/kong.yml:/kong/kong.yml:ro"
    ports:
      - "8000:8000"
      - "8443:8443"
      - "8001:8001"
    networks:
      - platform_net
    deploy:
      replicas: 1

networks:
  platform_net:
    external: true
