version: "3.8"

services:
  postgresql:
    image: postgres:16
    environment:
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: "{{ postgresql_password }}"
      POSTGRES_DB: app
    volumes:
      - "{{ swarm_data_root }}/postgresql:/var/lib/postgresql/data"
    networks:
      - platform_net
    deploy:
      replicas: 1
      placement:
        constraints:
          - node.labels.workload != storage

  mysql:
    image: mysql:8.4
    environment:
      MYSQL_ROOT_PASSWORD: "{{ mysql_root_password }}"
    volumes:
      - "{{ swarm_data_root }}/mysql:/var/lib/mysql"
    networks:
      - platform_net
    deploy:
      replicas: 1

  redis:
    image: redis:7.2
    command: ["redis-server", "--appendonly", "yes"]
    volumes:
      - "{{ swarm_data_root }}/redis:/data"
    networks:
      - platform_net
    deploy:
      replicas: 1

networks:
  platform_net:
    external: true
